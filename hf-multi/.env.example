# HuggingFace через OpenAI-совместимый router.
# Токен hf_... со страницы https://huggingface.co/settings/tokens
LLM_API_KEY=hf_ваш_токен
LLM_BASE_URL=https://router.huggingface.co/v1/chat/completions
# Модель из конфига приложением не используется (модели выбираются автоматически
# или флагом --models), но переменная обязательна — поставьте любую валидную:
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
