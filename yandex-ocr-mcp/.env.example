# Настройка MCP-сервера Yandex OCR. Скопируйте в .env и заполните.

# Авторизация (нужно одно из двух). Приоритет — у API-ключа сервисного аккаунта.
YANDEX_OCR_API_KEY=...
# YANDEX_IAM_TOKEN=...        # альтернатива: IAM-токен (живёт ~12 часов)

# Каталог (нужен при авторизации IAM-токеном):
# YANDEX_FOLDER_ID=...

# Необязательное (показаны значения по умолчанию):
# YANDEX_OCR_MODEL=page                 # page | handwritten | table | passport | …
# YANDEX_OCR_LANGUAGES=*                 # или, например, ru,en
# YANDEX_OCR_ENDPOINT=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
# YANDEX_OCR_TIMEOUT_MS=60000

# HTTP-режим (npm run start:http — для деплоя на VPS):
# PORT=3000
# Bearer-токен доступа к серверу. ОБЯЗАТЕЛЕН для публичного VPS (иначе любой
# сможет вызывать сервер и тратить твою квоту Yandex). Пусто — авторизация выключена.
# MCP_BEARER_TOKEN=задай-длинный-секрет
