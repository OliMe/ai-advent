{
  "name": "support-mcp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "description": "MCP-сервер доступа к тикет-системе как к CRM: обобщённый ticket-контракт (get_ticket/list_tickets/search_tickets/get_ticket_comments/add_ticket_comment) поверх сменного провайдера. Провайдер GitHub Issues; задел под GitLab/Jira/Zendesk/JSON. Инструменты отдают строгий JSON.",
  "scripts": {
    "start": "node src/cli.ts",
    "typecheck": "tsc",
    "test": "node --test --experimental-test-coverage --test-coverage-exclude='src/cli.ts' --test-coverage-exclude='src/server.ts' --test-coverage-exclude='src/__test__/**' --test-coverage-exclude='../core/**' --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 'src/__test__/**/*.test.ts'",
    "lint-prettier": "prettier \"src/**/*.ts\" --check",
    "write-prettier": "prettier \"src/**/*.ts\" --write"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100,
    "arrowParens": "avoid",
    "semi": true,
    "trailingComma": "all",
    "tabWidth": 2
  }
}
