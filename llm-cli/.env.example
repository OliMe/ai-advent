# Обязательные переменные.
# Подойдёт любой OpenAI-совместимый эндпоинт chat/completions
# (z.ai, OpenAI, OpenRouter, локальный Ollama/LM Studio и т.п.).
# Ниже — пример для z.ai (GLM):
LLM_API_KEY=ваш_ключ_здесь
LLM_BASE_URL=https://api.z.ai/api/paas/v4/chat/completions
LLM_MODEL=glm-5.1

# Необязательные (показаны значения по умолчанию):
# LLM_TEMPERATURE=0.7
# LLM_SYSTEM_PROMPT=Ты — полезный ассистент. Отвечай ясно и по делу на русском языке.
# Таймаут ожидания ответа модели в миллисекундах (по умолчанию 60000).
# LLM_REQUEST_TIMEOUT_MS=120000
# Размер контекстного окна выбранной модели в токенах (по умолчанию 8192).
# По нему в интерактивном чате история обрезается скользящим окном, чтобы
# не переполнить контекст. Поставьте под свою модель (напр. 32768, 131072).
# LLM_CONTEXT_TOKENS=8192
# Тарифы модели для оценки стоимости запроса, $ за 1M токенов (по умолчанию 0 —
# стоимость не считается). Возьмите из тарифа провайдера для своей модели:
# LLM_PRICE_INPUT_PER_1M=0.6
# LLM_PRICE_OUTPUT_PER_1M=2.2
# Курс доллара к рублю для вывода стоимости в ₽ (по умолчанию 90):
# LLM_USD_RUB=90
# Команда агентов на этап планирования. Потолок ролей (по умолчанию 4; 1 —
# многоагентность выключена, оркестратор не вызывается) и максимум одновременных
# запросов роль-агентов (по умолчанию 2, бережно к ограничениям провайдера):
# LLM_MAX_STAGE_AGENTS=4
# LLM_STAGE_AGENT_CONCURRENCY=2

# --- RAG-ответ (День 24, клиентская сторона) ---
# Эти переменные читает llm-cli (сборка ответа), НЕ rag-mcp. Ретрив/ранжирование/порог
# уверенности настраиваются отдельно — в rag-mcp/.env (RAG_RERANK/RAG_REWRITE/RAG_CONFIDENCE_MIN…).
# Компактный вид секций Источники/Цитаты (короткие источники, одна цитата) — для длинного чата:
# RAG_ANSWER_COMPACT=1
# Опциональный рантайм-судья достоверности (LLM сверяет, что утверждения опираются на цитаты).
# По умолчанию выкл — семантическая проверка капризна; тумблер для сравнения «с ним и без».
# RAG_FAITHFULNESS_CHECK=1
