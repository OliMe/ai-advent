# Те же переменные, что и у остальных пакетов (OpenAI-совместимый провайдер).
LLM_API_KEY=ваш_ключ_здесь
LLM_BASE_URL=https://api.z.ai/api/paas/v4/chat/completions
LLM_MODEL=glm-5.1

# Приложение делает несколько reasoning-запросов; на медленных ответах
# дефолтных 60 с может не хватить — задаём таймаут на запрос с запасом.
LLM_REQUEST_TIMEOUT_MS=180000
