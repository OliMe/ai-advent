# Настройка пробного MCP-клиента. Скопируйте в .env и заполните под свой сервер.

# Транспорт: stdio (локальный процесс) или http (Streamable HTTP).
# Можно не задавать — выведется из MCP_URL (http) или MCP_COMMAND (stdio).
# MCP_TRANSPORT=stdio

# --- stdio: запуск локального MCP-сервера ---
# MCP_COMMAND=npx
# MCP_ARGS=-y tavily-mcp
# Ключи для сервера кладите сюда же — всё окружение (включая .env) форвардится процессу.
# Пример для Tavily:
# TAVILY_API_KEY=tvly-xxxxx

# --- http: удалённый/локальный Streamable HTTP сервер ---
# MCP_URL=http://localhost:3000/mcp
# MCP_BEARER_TOKEN=xxxxx
# MCP_HEADERS=X-Api-Key: abc; X-Org: acme

# --- что запросить (по умолчанию — список инструментов) ---
# Имя инструмента удобнее передавать аргументом командной строки (см. README):
#   npm start -- tavily-search '{"query":"что такое MCP"}'
# Аргумент CLI важнее этих переменных. Эти — запасной вариант, если не задавать CLI-аргумент:
# MCP_TOOL=tavily-search
# MCP_TOOL_ARGS={"query":"что такое Model Context Protocol"}
