# Настройка MCP-сервера планировщика. Скопируйте в .env и заполните.

# Порт HTTP-режима. На общем VPS НЕ 3000 (занят yandex-ocr-mcp) — например 3001.
PORT=3001

# Bearer-токен доступа к серверу. ОБЯЗАТЕЛЕН для публичного VPS: без него любой сможет
# ставить задачи, в т.ч. http_check на произвольные URL (SSRF). Пусто — авторизация выключена.
MCP_BEARER_TOKEN=задай-длинный-секрет

# Путь к файлу состояния (задачи + история). Держите его внутри ReadWritePaths systemd-юнита.
SCHEDULER_STORE_PATH=/opt/scheduler-mcp/state.json

# Период фонового тика, мс (как часто проверять «созревшие» задачи). По умолчанию 15000.
SCHEDULER_TICK_MS=15000
