# Настройка MCP-сервера RAG. Скопируйте в .env и при желании измените.
# Файл читается ПО ПУТИ ПАКЕТА (rag-mcp/.env), а не из cwd, — поэтому конфиг одинаков,
# откуда бы сервер ни запустили, в т.ч. когда его поднимает llm-cli как MCP-процесс.
# Уже заданные переменные окружения (в т.ч. env-блок записи сервера в ~/.llm-cli/mcp.json)
# приоритетнее этого файла. Все переменные ОПЦИОНАЛЬНЫ — без .env всё работает на дефолтах.

# --- Выборка ---
# Стратегия чанкинга по умолчанию: fixed (размер+overlap) или structural (по заголовкам/файлам).
# RAG_STRATEGY=structural
# Сколько фрагментов отдавать в результат (итог после rerank).
# RAG_TOP_K=5
# Сколько доставать до стадии rerank/фильтра (kPre >= k): шире достаём — точнее сужаем.
# RAG_TOP_K_PRE=20

# --- Фильтрация и переранжирование (День 23) ---
# Порог косинуса на стадии фильтра (0..1). 0 — фильтр выключен.
# RAG_MIN_SCORE=0
# Режим переранжирования: none | mmr (релевантность+разнообразие) | llm (chat-модель проставляет скоры).
# RAG_RERANK=mmr
# Баланс релевантность/разнообразие для MMR (0..1): ближе к 1 — релевантность, к 0 — разнообразие.
# RAG_MMR_LAMBDA=0.7

# --- Переписывание запроса (День 23) ---
# Режим: none | expand (обогащение синонимами) | hyde (гипотетический документ-ответ, его и эмбеддим).
# RAG_REWRITE=none

# --- Префиксы задачи nomic (День 23) ---
# Разные префиксы для запроса и документа (модель различает «вопрос» и «пассаж»). Меняются вместе с
# моделью эмбеддингов. ПУСТАЯ строка отключает префикс (для моделей, которым он не нужен).
# Хвостовой пробел значим — берите в кавычки, иначе .env его обрежет.
# RAG_QUERY_PREFIX="search_query: "
# RAG_DOC_PREFIX="search_document: "

# --- Кэш и индексация ---
# Каталог кэша индексов (ключ учитывает источник + стратегию + «схему» эмбеддинга).
# RAG_CACHE_DIR=~/.rag-mcp/indexes
# Глубина веб-обхода при индексации URL.
# RAG_CRAWL_DEPTH=2
# Параметры чанкинга: размер/overlap для fixed, макс. размер раздела для structural.
# RAG_CHUNK_SIZE=2000
# RAG_CHUNK_OVERLAP=256
# RAG_MAX_SECTION=2000

# --- Эмбеддинги ---
# По умолчанию — локальный Ollama (без ключа): `ollama serve` + `ollama pull nomic-embed-text`.
# Сменить на удалённый OpenAI-совместимый эндпоинт:
# LLM_EMBEDDINGS_URL=http://localhost:11434/v1/embeddings
# LLM_EMBEDDINGS_MODEL=nomic-embed-text
# LLM_EMBEDDINGS_API_KEY=...

# --- Chat-модель для rewrite/LLM-реранка (День 23) ---
# Нужна ТОЛЬКО при RAG_REWRITE=expand|hyde или RAG_RERANK=llm. Сначала берутся RAG_LLM_*,
# при их отсутствии — фолбэк на ядровые LLM_*. Не заданы ни те, ни другие → эти стадии выключены.
# RAG_LLM_API_KEY=...
# RAG_LLM_BASE_URL=https://api.deepseek.com
# RAG_LLM_MODEL=deepseek-chat
# Температура (стабильнее на низкой). По умолчанию 0.2.
# RAG_LLM_TEMPERATURE=0.2
# Отключить «рассуждения» модели — нужно для GLM (для deepseek необязательно). 1 или true.
# RAG_LLM_NO_THINKING=1
